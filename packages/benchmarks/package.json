{
  "name": "@nexus/benchmarks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "tsx src/index.ts",
    "bench:graph": "tsx src/graph-benchmarks.ts",
    "bench:search": "tsx src/search-benchmarks.ts",
    "bench:crdt": "tsx src/crdt-benchmarks.ts",
    "test": "vitest run --no-cache",
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nexus/shared": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
