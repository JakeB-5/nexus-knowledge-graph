{
  "name": "@nexus/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "nexus": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "test": "vitest run --no-cache",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nexus/sdk": "workspace:*",
    "@nexus/shared": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  }
}
