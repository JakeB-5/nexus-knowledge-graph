{
  "name": "@nexus/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "vitest run --no-cache",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@nexus/db": "workspace:*",
    "@nexus/graph": "workspace:*",
    "@nexus/search": "workspace:*",
    "@nexus/shared": "workspace:*",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "argon2": "^0.41.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  }
}
